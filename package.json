{
  "name": "ideate-core",
  "version": "0.2.0",
  "description": "A provider-agnostic, evidence-based ideation engine: independent multi-agent generation, blind→pool brainwriting rounds, embedding-dedup + clustering + split-axis convergence, and an evaluate→regenerate feedback loop — as a zero-dependency injectable function. Bring your own model, embedder, and prompts.",
  "keywords": [
    "ideation",
    "brainstorming",
    "brainwriting",
    "multi-agent",
    "llm",
    "divergent-thinking",
    "creativity",
    "nominal-group",
    "provider-agnostic",
    "zero-dependency",
    "embeddings",
    "clustering"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./lib/ideate-core.mjs",
    "./converge": "./lib/converge.mjs",
    "./feedback": "./lib/feedback.mjs",
    "./integrations/headless-cli": "./integrations/headless-cli/index.mjs",
    "./integrations/subagent-dispatch": "./integrations/subagent-dispatch/index.mjs"
  },
  "bin": { "ideate": "bin/ideate.mjs" },
  "files": [
    "lib",
    "bin",
    "docs",
    "integrations",
    "NOTICE",
    "!lib/*.test.mjs",
    "!integrations/**/*.test.mjs",
    "!docs/assets/hero.png"
  ],
  "scripts": {
    "test": "node --test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kromatic-Innovation/ideate-core.git"
  },
  "homepage": "https://github.com/Kromatic-Innovation/ideate-core#readme",
  "bugs": {
    "url": "https://github.com/Kromatic-Innovation/ideate-core/issues"
  },
  "author": "Kromatic Innovation (https://www.kromatic.com/)",
  "engines": { "node": ">=20" }
}
